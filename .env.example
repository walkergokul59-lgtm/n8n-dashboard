## Dashboard server -> n8n connection
N8N_BASE_URL=http://localhost:5678
N8N_API_BASE_PATH=/api/v1
N8N_API_TOKEN=replace_me
N8N_AUTH_TYPE=header
N8N_AUTH_HEADER=X-N8N-API-KEY

## Dashboard app auth
APP_AUTH_SECRET=replace_with_long_random_string

## Optional RBAC config path (local file mode)
# RBAC_CONFIG_PATH=./data/rbac.json

